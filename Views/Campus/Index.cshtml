@model IEnumerable<Building>
@{
    ViewData["Title"] = "Wirtualna Uczelnia";
}
<a class="visually-hidden-focusable skip-link" href="#maincontent">Przejdź do treści</a>

<div id="maincontent" class="container">
    <h1 class="mt-3">Wirtualna Uczelnia</h1>
    <p class="text-muted">Wybierz budynek, aby rozpocząć spacer. Aplikacja jest dostępna z klawiatury.</p>

    <div class="row row-cols-1 row-cols-md-2 g-3">
        @foreach (var b in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h2 class="h5 card-title">@(!string.IsNullOrWhiteSpace(b.Code) ? $"{b.Code} – {b.Name}" : b.Name)</h2>
                        @if (!string.IsNullOrWhiteSpace(b.Description))
                        {
                            <p class="card-text">@b.Description</p>
                        }
                        <a class="btn btn-primary" asp-action="Building" asp-route-id="@b.Id">Wejdź do budynku</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
