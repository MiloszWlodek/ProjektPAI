@model Building
@{
    ViewData["Title"] = $"Budynek {Model.Code}";
}

<div class="container">
    <nav aria-label="Breadcrumb" class="mt-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Wirtualna Uczelnia</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <h1>@Model.Name</h1>
    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <p>@Model.Description</p>
    }

    <h2 class="h4 mt-4">Piętra</h2>
    <ul class="list-group">
        @foreach (var f in Model.Floors.OrderBy(x => x.Level))
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>@f.Name</span>
                <a class="btn btn-outline-primary btn-sm" asp-action="Floor" asp-route-id="@f.Id">Otwórz</a>
            </li>
        }
    </ul>

    <div class="mt-4">
        <a class="btn btn-secondary" asp-action="Index">Powrót</a>
    </div>
</div>
