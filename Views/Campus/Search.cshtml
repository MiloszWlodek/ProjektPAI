@model RoomSearchViewModel
@{
    ViewData["Title"] = "Szukaj sal";
}

<div class="container">
    <h1 class="mt-3">Szukaj sal</h1>

    <form method="get" class="row g-2" asp-action="Search">
        <div class="col-12 col-md-8">
            <label for="q" class="form-label">Fraza</label>
            <input id="q" name="q" class="form-control" type="search" value="@Model.Query" />
        </div>
        <div class="col-12 col-md-4 d-flex align-items-end">
            <button class="btn btn-primary w-100" type="submit">Szukaj</button>
        </div>
    </form>

    <h2 class="h4 mt-4">Wyniki</h2>
    <ul class="list-group">
        @foreach (var r in Model.Results)
        {
            <li class="list-group-item">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <strong>@r.Name</strong>
                        <div class="text-muted">@r.Floor?.Building?.Code – @r.Floor?.Name</div>
                    </div>
                    <a class="btn btn-outline-primary btn-sm" asp-action="Room" asp-route-id="@r.Id">Szczegóły</a>
                </div>
            </li>
        }
    </ul>
</div>
