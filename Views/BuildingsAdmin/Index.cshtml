@model IEnumerable<Building>
@{
    ViewData["Title"] = "Budynki";
}
<div class="container">
    <h1 class="mt-3">Budynki</h1>
    <a class="btn btn-primary mb-3" asp-action="Create">Dodaj budynek</a>

    <table class="table table-striped">
        <thead><tr><th>Kod</th><th>Nazwa</th><th></th></tr></thead>
        <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td>@b.Code</td>
                <td>@b.Name</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@b.Id">Szczegóły</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@b.Id">Edytuj</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@b.Id">Usuń</a>
                </td>
            </tr>
        }
        </tbody>
    </table>

    <a class="btn btn-outline-secondary" asp-controller="CampusAdmin" asp-action="Index">Powrót do panelu</a>
</div>
