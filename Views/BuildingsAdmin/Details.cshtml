@model Building
@{
    ViewData["Title"] = "Szczegóły budynku";
}
<div class="container">
  <h1 class="mt-3">@Model.Name</h1>
  <dl class="row">
    <dt class="col-sm-3">Kod</dt><dd class="col-sm-9">@Model.Code</dd>
    <dt class="col-sm-3">Lokalizacja</dt><dd class="col-sm-9">@Model.Location</dd>
    <dt class="col-sm-3">Opis</dt><dd class="col-sm-9">@Model.Description</dd>
  </dl>
  <a class="btn btn-outline-secondary" asp-action="Index">Powrót</a>
</div>
