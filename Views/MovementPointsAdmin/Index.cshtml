@model IEnumerable<MovementPoint>
@{
    ViewData["Title"] = "Punkty ruchu";
}
<div class="container">
    <h1 class="mt-3">Punkty ruchu</h1>
    <a class="btn btn-primary mb-3" asp-action="Create">Dodaj punkt</a>

    <table class="table table-striped">
        <thead><tr><th>Budynek</th><th>Piętro</th><th>Nazwa</th><th></th></tr></thead>
        <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Floor?.Building?.Code</td>
                <td>@p.Floor?.Name</td>
                <td>@p.Name</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@p.Id">Szczegóły</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@p.Id">Edytuj</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@p.Id">Usuń</a>
                </td>
            </tr>
        }
        </tbody>
    </table>

    <a class="btn btn-outline-secondary" asp-controller="CampusAdmin" asp-action="Index">Powrót do panelu</a>
</div>
