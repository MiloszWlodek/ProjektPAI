@model IEnumerable<Floor>
@{
    ViewData["Title"] = "Piętra";
}
<div class="container">
    <h1 class="mt-3">Piętra</h1>
    <a class="btn btn-primary mb-3" asp-action="Create">Dodaj piętro</a>

    <table class="table table-striped">
        <thead><tr><th>Budynek</th><th>Nazwa</th><th>Poziom</th><th></th></tr></thead>
        <tbody>
        @foreach (var f in Model)
        {
            <tr>
                <td>@f.Building?.Code</td>
                <td>@f.Name</td>
                <td>@f.Level</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@f.Id">Szczegóły</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@f.Id">Edytuj</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@f.Id">Usuń</a>
                </td>
            </tr>
        }
        </tbody>
    </table>

    <a class="btn btn-outline-secondary" asp-controller="CampusAdmin" asp-action="Index">Powrót do panelu</a>
</div>
