@model Floor
@{
    ViewData["Title"] = "Szczegóły piętra";
}
<div class="container">
  <h1 class="mt-3">@Model.Name</h1>
  <dl class="row">
    <dt class="col-sm-3">Budynek</dt><dd class="col-sm-9">@Model.Building?.Name</dd>
    <dt class="col-sm-3">Poziom</dt><dd class="col-sm-9">@Model.Level</dd>
    <dt class="col-sm-3">Plan</dt><dd class="col-sm-9">@Model.PlanImagePath</dd>
  </dl>
  <a class="btn btn-outline-secondary" asp-action="Index">Powrót</a>
</div>
