@model Floor
@{ ViewData["Title"] = "Dodaj piętro"; }
<div class="container">
  <h1 class="mt-3">Dodaj piętro</h1>
  <form asp-action="Create" method="post">
    <div class="mb-3">
  <label class="form-label" for="BuildingId">Budynek</label>
  <select class="form-select" asp-for="BuildingId" asp-items="ViewBag.BuildingId"></select>
  <span asp-validation-for="BuildingId" class="text-danger"></span>
</div>
<div class="mb-3">
  <label asp-for="Name" class="form-label"></label>
  <input asp-for="Name" class="form-control" />
  <span asp-validation-for="Name" class="text-danger"></span>
</div>
<div class="mb-3">
  <label asp-for="Level" class="form-label"></label>
  <input asp-for="Level" class="form-control" type="number" />
  <span asp-validation-for="Level" class="text-danger"></span>
</div>
<div class="mb-3">
  <label asp-for="PlanImagePath" class="form-label"></label>
  <input asp-for="PlanImagePath" class="form-control" placeholder="/img/plan-parter.png" />
  <span asp-validation-for="PlanImagePath" class="text-danger"></span>
</div>
    <button class="btn btn-primary" type="submit">Zapisz</button>
    <a class="btn btn-outline-secondary" asp-action="Index">Anuluj</a>
  </form>
</div>
@section Scripts{<partial name="_ValidationScriptsPartial" />}
